        },
        "tags": [
            "Example"
        ],
        "style": {
            "node_label": "Example Sleep Piece",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa-solid:database",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "This is an example of a simple Domino Piece that sleep for N seconds",
