                }
            },
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "description": "Sleep Piece Output Model",
            "properties": {
                "message": {
                    "description": "Sleep piece executed",
                    "title": "Message",
                    "type": "string"
                }
            },
            "required": [
                "message"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/olliekm/domino_pieces_repository_template/tree/main/pieces/ExampleSleepPiece"
